# Server
HOST=0.0.0.0
PORT=8000
DATABASE_URL=sqlite:///./data/cs2_scraper.db
REQUEST_TIMEOUT=15

# Scraper Sources
ENABLE_YOUPIN=true
ENABLE_BUFF=true
ENABLE_SKINPORT=true
ENABLE_CSFLOAT=false
ENABLE_ECOSTEAM=false
ENABLE_C5GAME=false

# Background Scraper
SCRAPE_INTERVAL_MINUTES=30

# Auth (optional — API is open by default)
SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=168

# Marketplace Auth (optional — required for live Buff/Youpin search)
# Get your Buff session cookie from browser dev tools after logging in to buff.163.com
BUFF_SESSION_COOKIE=
# Get your Youpin token from browser dev tools Network tab after logging in to youpin898.com
YOUPIN_TOKEN=
YOUPIN_DEVICE_ID=

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=60

# Marketplace API Base URLs (rarely need changing)
YOUPIN_BASE_URL=https://api.youpin898.com
BUFF_BASE_URL=https://buff.163.com
SKINPORT_BASE_URL=https://api.skinport.com/v1
CSFLOAT_BASE_URL=https://csfloat.com/api/v1
ECOSTEAM_BASE_URL=https://openapi.ecosteam.cn
C5GAME_BASE_URL=https://www.c5game.com
